# Porta em que o servidor HTTP irá escutar
PORT=3000

# Caminho para o arquivo JSON que armazena os dados dos filmes e séries
# Relativo à raiz do projeto
DATA_FILE=data/filmes.json

# Chave da API TMDB (The Movie Database) para busca de filmes e séries
# Obtenha gratuitamente em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
